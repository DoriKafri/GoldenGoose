# Required
ANTHROPIC_API_KEY=sk-ant-...

# Database (default: SQLite in project root)
DATABASE_URL=sqlite:///./venture_engine.db

# Optional: Slack webhook for notifications
NOTIFY_WEBHOOK_URL=https://hooks.slack.com/services/...

# Optional: API key for write operations
API_KEY=changeme

# Optional: SerpAPI key for Twitter/X search fallback
SERPAPI_KEY=

# Scheduler settings
HARVEST_INTERVAL_HOURS=4
GAP_CHECK_HOUR=8
TL_SYNC_INTERVAL_HOURS=12
WEEKLY_DIGEST_DAY=mon
WEEKLY_DIGEST_HOUR=9
